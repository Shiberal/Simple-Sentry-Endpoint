// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Example model - you can modify this as needed
enum IssueStatus {
  UNRESOLVED
  RESOLVED
  IGNORED
  IN_PROGRESS
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  name            String?
  password        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  projects        Project[] @relation("ProjectUsers")
  assignedIssues  Issue[]   @relation("AssignedIssues")
  comments        Comment[]
}

model Project {
  id          Int         @id @default(autoincrement())
  name        String
  key         String      @unique // Unique key for the project (like Sentry DSN)
  githubRepo  String?     // GitHub repository (e.g., "owner/repo" or full URL)
  githubToken String?     // Optional GitHub personal access token for API access
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  events      Event[]
  users       User[]      @relation("ProjectUsers")
  issues      Issue[]
  alertRules  AlertRule[]
}

model Issue {
  id           Int         @id @default(autoincrement())
  projectId    Int
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fingerprint  String      // Hash of error signature for grouping
  title        String      // Error message/title
  culprit      String?     // Function/file where error occurred
  level        String      @default("error") // error, warning, info
  status       IssueStatus @default(UNRESOLVED)
  count        Int         @default(1) // Number of occurrences
  firstSeen    DateTime    @default(now())
  lastSeen     DateTime    @default(now())
  assignedToId Int?
  assignedTo   User?       @relation("AssignedIssues", fields: [assignedToId], references: [id], onDelete: SetNull)
  events       Event[]
  comments     Comment[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([projectId, fingerprint])
  @@index([projectId, status])
  @@index([projectId, lastSeen])
}

model Event {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issueId   Int?
  issue     Issue?   @relation(fields: [issueId], references: [id], onDelete: SetNull)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([issueId])
  @@index([projectId, createdAt])
}

model Comment {
  id        Int      @id @default(autoincrement())
  issueId   Int
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@index([issueId])
}

model AlertRule {
  id              Int      @id @default(autoincrement())
  projectId       Int
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  enabled         Boolean  @default(true)
  condition       Json     // { level: ["error"], environment: "production", etc. }
  emailRecipients String   // Comma-separated email addresses
  lastTriggered   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId, enabled])
}

